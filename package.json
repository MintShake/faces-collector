{
  "name": "farcaster-fid-kafka-logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "start:hosted": "node scripts/start-hosted.mjs",
    "build": "tsc",
    "topics": "tsx src/setup-topics.ts",
    "log:fids": "tsx src/log-unique-fids.ts",
