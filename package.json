  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1055.0",
    "@farcaster/hub-nodejs": "^0.16.0",
    "@vercel/blob": "^2.4.0",
    "better-sqlite3": "^12.10.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "kafkajs": "^2.2.4",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
